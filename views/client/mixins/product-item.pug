mixin product-item(item)
  - const discount = parseInt(((item.priceAdult - item.priceNewAdult) / item.priceAdult) * 100);

  .product-item
    .inner-image
      a(href=`/tour/detail/${item.slug}`)
        img(
          alt=item.name
          src=item.avatar
        )
    .inner-discount
      i.fa-solid.fa-bolt
      | Giảm -#{discount}%
    .inner-content
      h3.inner-title
        a(href=`/tour/detail/${item.slug}`) #{item.name}
      .inner-prices
        if(discount > 0)
        .inner-price-old
            | #{item.priceAdult.toLocaleString("vi-VN")}
            span.inner-unit đ
        .inner-price-new
          | #{item.priceNewAdult.toLocaleString("vi-VN")}
          span.inner-unit đ
      .inner-desc
        .inner-desc-item
          | Ngày Khởi Hành:
          b #{item.departureDateFormat}
        .inner-desc-item
          | Thời Gian:
          b #{item.time}
      .inner-meta
        if item.stockAdult === 0
          a.inner-contact-booking(
            href=`tel:${settingWebsiteInfo && settingWebsiteInfo.phone ? settingWebsiteInfo.phone : ''}`
            style="display:inline-flex; align-items:center; gap:6px; background:#455A64; color:#fff; border-radius:6px; padding:6px 14px; font-size:12px; font-weight:600; text-decoration:none;"
          )
            i.fa-solid.fa-phone(style="font-size:11px;")
            | Liên hệ để đặt chỗ
        else
          .inner-stock
            .inner-label Số chỗ còn:
            .inner-number #{item.stockAdult}
