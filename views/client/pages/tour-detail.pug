extends ../layouts/default.pug
include ../mixins/box-breadcrumb.pug

block main
    +box-breadcrumb(breadcrumb)
    // End Breadcrumb
    
    // Section 10
    .section-10
      .container
        .inner-wrap
          .inner-left
            .box-images
              .inner-images-main
                .swiper.swiper-box-images-main
                  .swiper-wrapper
                    each image in tourDetail.images
                      .swiper-slide
                        .inner-image
                          img(
                            alt="" 
                            src=image
                            )
              .inner-images-thumb
                .swiper.swiper-box-images-thumb
                  .swiper-wrapper
                    each image in tourDetail.images
                      .swiper-slide
                        .inner-image
                          img(
                            alt="" 
                            src=image
                            )
            .box-tour-info
              .inner-title Thông Tin Tour
              .inner-content !{tourDetail.information}
              .inner-read-more
                button.button-outline Xem tất cả
            .box-tour-schedule
              .inner-title-main Lịch Trình Tour
              .inner-list
                each item in tourDetail.schedules
                  .inner-item
                    .inner-title #{item.title}
                    .inner-content !{item.description}
          .inner-right
            .box-tour-detail
              .inner-title-main Chuyến Đi Của Bạn
              .inner-product
                .inner-image
                  img(
                    alt="" 
                    src=tourDetail.avatar
                    )
                .inner-info
                  .inner-title #{tourDetail.name}
              .inner-meta
                .inner-item
                  i.fa-solid.fa-calendar-days
                  span Thời Gian:
                  span.inner-highlight #{tourDetail.time}
                .inner-item
                  i.fa-solid.fa-truck-plane
                  span Phương Tiện:
                  span.inner-highlight #{tourDetail.vehicle}
                .inner-item
                  i.fa-solid.fa-calendar-days
                  span Ngày Khởi Hành:
                  span.inner-highlight #{tourDetail.departureDateFormat}
              .inner-form
                label.inner-label Khởi Hành Tại:
                select(location-from)
                  each item in cityList
                    option(value=item.id) #{item.name}
              .inner-quantity
                label.inner-label Số Lượng Hành Khách
                p(style="font-size:11px; color:#e07b00; margin: 4px 0 10px 0; line-height:1.5;")
                  | ⚠️ Tối thiểu 1 người lớn. Mỗi người lớn kèm tối đa 2 trẻ em &amp; 1 em bé.
                .inner-list
                  .inner-item
                    .inner-item-label Người lớn:
                    .inner-item-input
                      input(
                        value="1"
                        min="1"
                        max=tourDetail.stockAdult
                        type="number"
                        input-stock-adult
                        price=tourDetail.priceNewAdult
                        stock-max=tourDetail.stockAdult
                        )
                    .inner-item-price
                      span(stock-adult) 1
                      span &nbsp;x&nbsp;
                      span.inner-highlight #{tourDetail.priceNewAdult.toLocaleString("vi-VN")}
                    span(style="font-size:11px; color:#888; margin-left:6px; white-space:nowrap;")
                      | (Còn #{tourDetail.stockAdult})
                  .inner-item
                    .inner-item-label Trẻ em:
                    .inner-item-input
                      input(
                        value="0"
                        min="0"
                        max=tourDetail.stockChildren
                        type="number"
                        input-stock-children
                        price=tourDetail.priceNewChildren
                        stock-max=tourDetail.stockChildren
                        )
                    .inner-item-price
                      span(stock-children) 0
                      span &nbsp;x&nbsp;
                      span.inner-highlight #{tourDetail.priceNewChildren.toLocaleString("vi-VN")}
                    span(style="font-size:11px; color:#888; margin-left:6px; white-space:nowrap;")
                      | (Còn #{tourDetail.stockChildren})
                  .inner-item
                    .inner-item-label Em bé:
                    .inner-item-input
                      input(
                        value="0"
                        min="0"
                        max=tourDetail.stockBaby
                        type="number"
                        input-stock-baby
                        price=tourDetail.priceNewBaby
                        stock-max=tourDetail.stockBaby
                        )
                    .inner-item-price
                      span(stock-baby) 0
                      span &nbsp;x&nbsp;
                      span.inner-highlight #{tourDetail.priceNewBaby.toLocaleString("vi-VN")}
                    span(style="font-size:11px; color:#888; margin-left:6px; white-space:nowrap;")
                      | (Còn #{tourDetail.stockBaby})
              .inner-total
                .inner-total-label Tổng cộng:
                .inner-total-price
                  span(total-price) #{tourDetail.priceNewAdult.toLocaleString("vi-VN")}
                  span đ
              button.inner-button-add-cart(tour-id=tourDetail.id) Thêm Vào Giỏ Hàng

    // End Section 10
